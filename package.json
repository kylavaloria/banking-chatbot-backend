{
  "name": "bfsi-chatbot-backend",
  "version": "1.0.0",
  "description": "BFSI Chatbot MVP – Express + TypeScript backend",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest-kb": "ts-node scripts/ingest-kb.ts",
    "sla-job":   "ts-node src/jobs/run-sla-job.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  }
}
